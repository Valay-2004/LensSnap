{
  "manifest_version": 3,
  "name": "LensSnap",
  "version": "1.0",
  "description": "This extension let's you capture your webpage with variable size and then search it on multiple image search engines",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "clipboardWrite",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Capture & Search",
    "default_icon": "icons/icon.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}
